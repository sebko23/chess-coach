# CHESS COACH backend — example environment variables.
#
# Copy this file to .env (which is gitignored) and edit the values
# to match your setup. The .env file is auto-loaded by the gateway
# via python-dotenv (see services/chess_coach/gateway/__main__.py).
#
# Alternatively, you can export these in your shell, or set them in
# docker-compose.yml's `environment:` block. The .env file is
# only useful for the local-venv workflow (BBF-27 docs).

# --- backend auth ---
# The bearer token the gateway requires on every request. The
# gateway writes this same value to ${CHESS_COACH_DATA_DIR}/runtime/
# backend.json as the descriptor's session_token.
#
# For local dev, set this to a known value (e.g. devtoken123) so
# curl can use it without re-reading backend.json:
#   curl -H "Authorization: Bearer *** http://...
#
# If unset, the gateway auto-generates a random token on startup.
CHESS_COACH_BACKEND_TOKEN=devtoken123

# --- parallelism ---
# How many Stockfish subprocesses to spawn. Each process is
# single-coroutine (Stockfish's protocol), so 1 is correct for a
# single-user setup. Set to your CPU core count for max
# parallelism, but each process spawns its own OS thread; values
# above ~4 can hit the per-process thread limit on the host
# (see docs/17_lazy_eval_graph/RESULTS.md for the "can't start
# new thread" failure mode).
#
# The agentZero dev machine is an i3-6100 (4 cores). For
# consistency with the perf-debug skill's verification runs,
# the default in docker-compose.yml is 1. Raise to 2-4 on a
# beefier host.
CHESS_COACH_MAX_WORKERS=1

# --- data dir ---
# Where the SQLite DB, runtime descriptor, and engine binaries
# live. The desktop reads ${CHESS_COACH_DATA_DIR}/runtime/backend.json
# to find the gateway. If you set this to a shared directory
# (e.g. an NFS mount), the desktop and the backend can be on
# different machines.
#
# Linux/macOS default if unset:
#   ~/.local/share/chess-coach
# Windows default if unset:
#   %LOCALAPPDATA%\chess-coach
CHESS_COACH_DATA_DIR=$HOME/.local/share/chess-coach

# --- optional: network ---
# Bind address. Defaults to 0.0.0.0 (listen on all interfaces).
# The descriptor's announced host is 127.0.0.1 when binding to
# 0.0.0.0 (the wildcard isn't routable on Windows/macOS). For
# docker-compose, this is 0.0.0.0 so the published port works.
# For local venv behind a reverse proxy, set this to 127.0.0.1.
# CHESS_COACH_HOST=0.0.0.0

# Port. 0 = OS-assigned ephemeral port (use 18080 for the dev
# default; matches docker-compose.yml and the smoke test).
CHESS_COACH_PORT=18080
